# 多云资源监控主线（推荐）
ALIYUN_ACCESS_KEY_ID=your-ak
ALIYUN_ACCESS_KEY_SECRET=your-secret
ALIYUN_METRIC_PERIOD=60
HUAWEI_ACCESS_KEY_ID=your-ak
HUAWEI_ACCESS_KEY_SECRET=your-secret
HUAWEI_METRIC_PERIOD=60

# 地域变量仅用于环境变量单账号兜底或接口调试限定范围，控制台账号默认自动发现全部地域。
# ALIYUN_REGION=cn-hangzhou
# ALIYUN_REGIONS=cn-hangzhou
# HUAWEI_REGION=cn-south-1
# HUAWEI_REGIONS=cn-south-1

# 文件入云扩展能力（按需开启）
OSS_BUCKET=
OSS_ENDPOINT=
OSS_REGION=
OSS_FORCE_PATH_STYLE=false
OSS_DISABLE_SSL=false
OSS_AK=
OSS_SK=

# 通知扩展（按需开启）
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
ROBOT_KEY=
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_FROM=
EMAIL_TO=
EMAIL_USE_TLS=true

# AI 扩展（按需开启）
AI_ENABLED=false
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT=20s
AI_MAX_LINES=200

# 知识库分块参数
KB_RAG_CHUNK_SIZE=420
KB_RAG_CHUNK_OVERLAP=80

# CORS
API_CORS_ORIGINS=http://localhost:8081,http://localhost:5173

# 本地数据目录（SQLite）
CONTROL_DATA_DIR=data/control
CLOUD_DATA_DIR=data/cloud
KB_DATA_DIR=data/kb

# 文件入云持久化队列
UPLOAD_QUEUE_PERSIST_ENABLED=false
UPLOAD_QUEUE_PERSIST_FILE=logs/upload-queue.json
UPLOAD_QUEUE_SATURATION_THRESHOLD=0.9
UPLOAD_QUEUE_CIRCUIT_BREAKER_ENABLED=true
UPLOAD_RETRY_MAX_ATTEMPTS=4
UPLOAD_ETAG_VERIFY_ENABLED=false
UPLOAD_RESUMABLE_ENABLED=false
UPLOAD_RESUMABLE_PART_SIZE=10485760
UPLOAD_RESUMABLE_ROUTINES=1
UPLOAD_RESUMABLE_THRESHOLD=10485760
UPLOAD_RESUMABLE_CHECKPOINT_DIR=logs/upload-checkpoints
